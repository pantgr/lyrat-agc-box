# secrets.yaml.example — ESPHome secrets template
#
# Copy this file to `secrets.yaml` (same folder as lyrat.yaml in your HA
# /config/esphome/ directory) and fill in real values. ESPHome will resolve
# every `!secret <name>` reference in lyrat.yaml from this file at compile time.
#
# DO NOT commit your real `secrets.yaml` to git — keep it local only.

# WiFi to connect to during normal operation
wifi_ssid: "YourHomeNetworkSSID"
wifi_password: "your-wifi-password"

# Home Assistant API encryption key.
# Generate with:  python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Or let ESPHome dashboard auto-generate one when you first add the device.
api_encryption_key: "REPLACE_ME_with_base64_encoded_32_byte_key"

# OTA update password — anyone on your LAN with this can flash new firmware to the board.
# Generate a random one:  openssl rand -hex 16
ota_password: "REPLACE_ME_with_random_hex_string"

# Fallback AP that the board exposes when it can't reach your home WiFi.
# Connect to this SSID from a phone to access the captive portal and reconfigure.
ap_fallback_ssid: "Lyrat Fallback Hotspot"
ap_fallback_password: "REPLACE_ME_min_8_chars"
